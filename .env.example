APP_NAME=Verdict Digital
ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DATABASE
SQL_ECHO=false

LOG_LEVEL=INFO

OPENAI_API_KEY=
OPENAI_MODEL=

AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_ENDPOINT_URL=

POLITICAL_SCHEDULER_ENABLED=true
POLITICAL_SCHEDULER_POLL_SECONDS=60
POLITICAL_SCHEDULER_DEFAULT_INTERVAL_MINUTES=1
POLITICAL_SCRAPE_QUERY=(politics OR election OR government OR policy)
POLITICAL_SCRAPE_MAX_PER_SOURCE=20
POLITICAL_HTTP_TIMEOUT_SECONDS=10
POLITICAL_SOURCE_GDELT_ENABLED=true
POLITICAL_SOURCE_GNEWS_ENABLED=false
GNEWS_API_KEY=

WEEKLY_FAUCET_AMOUNT=1000
PUBLIC_WEB_BASE_URL=https://verdict.digital
CORS_ALLOW_ORIGINS=["http://localhost:8080","http://127.0.0.1:8080","http://localhost:4173","http://127.0.0.1:4173","http://localhost:5173","http://127.0.0.1:5173","http://localhost:5174","http://127.0.0.1:5174"]

AUTH_SECRET_KEY=change-this
AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=10080
